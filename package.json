{
  "private": true,
  "scripts": {
    "start": "set NODE_OPTIONS=--openssl-legacy-provider && umi dev",
    "build": "set NODE_OPTIONS=--openssl-legacy-provider && umi build",
    "prettier": "prettier --write '**/*.{js,jsx,tsx,ts,less,md,json}'",
    "test": "umi-test",
    "test:coverage": "umi-test --coverage"
  },
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,less,md,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "prettier --parser=typescript --write"
    ]
  },
  "dependencies": {
    "@ant-design/pro-layout": "^6.5.0",
    "dotenv": "^17.4.2",
    "qiniu": "^7.15.1",
    "react": "17.x",
    "react-dom": "17.x",
    "react-lottie-player": "^1.4.3",
    "react-photo-view": "^1.2.7",
    "react-player": "^2.10.1",
    "styled-components": "^5.3.5",
    "umi": "^3.5.24"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/qiniu": "^6.1.0",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@types/styled-components": "^5.1.25",
    "@umijs/preset-react": "1.x",
    "@umijs/test": "^3.5.24",
    "file-loader": "^6.2.0",
    "lint-staged": "^10.0.7",
    "prettier": "^2.2.0",
    "typescript": "^4.1.2",
    "yorkie": "^2.0.0"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
